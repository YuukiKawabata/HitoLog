rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userID) {
      return signedIn() && request.auth.uid == userID;
    }

    function signedInUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && signedInUser().data.isAdmin == true
        && signedInUser().data.isDeleted != true
        && signedInUser().data.isSuspended != true;
    }

    function isActiveAccount() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && signedInUser().data.isDeleted != true
        && signedInUser().data.isSuspended != true;
    }

    function changedOnly(allowed) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(allowed);
    }

    function validPostMediaItems(data) {
      return !data.keys().hasAny(['mediaItems'])
        || (data.mediaItems is list && data.mediaItems.size() <= 4);
    }

    function validPostTopics(data) {
      return !data.keys().hasAny(['topics'])
        || (data.topics is list && data.topics.size() <= 8);
    }

    function validPostSearchTokens(data) {
      return !data.keys().hasAny(['searchTokens'])
        || (data.searchTokens is list && data.searchTokens.size() <= 80);
    }

    function validCommentPermission(data) {
      return data.keys().hasAll(['commentPermission'])
        && data.commentPermission in ['everyone', 'following', 'closed'];
    }

    function validTopicValue(topic) {
      return topic is string
        && topic.size() > 0
        && topic.size() <= 32;
    }

    function validTopicRoom(data) {
      return data.keys().hasOnly([
          'topic',
          'title',
          'description',
          'postCount',
          'followerCount',
          'lastPostAt',
          'createdAt',
          'updatedAt',
          'isOfficial',
          'moderationStatus'
        ])
        && validTopicValue(data.topic)
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 60
        && data.description is string
        && data.description.size() <= 240
        && data.postCount is int
        && data.postCount >= 0
        && data.followerCount is int
        && data.followerCount >= 0
        && data.isOfficial is bool
        && data.moderationStatus in ['active', 'reviewRequired', 'hidden'];
    }

    function validFeedControl(data) {
      return data.keys().hasOnly([
          'userID',
          'targetType',
          'targetID',
          'preference',
          'createdAt',
          'updatedAt'
        ])
        && data.userID is string
        && data.targetType == 'topic'
        && validTopicValue(data.targetID)
        && data.preference in ['boost', 'reduce']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function validReaction(data) {
      return data.keys().hasOnly(['postID', 'userID', 'kind', 'createdAt'])
        && data.postID is string
        && data.postID.size() > 0
        && data.userID is string
        && data.kind in ['empathy', 'insight', 'cheer']
        && data.createdAt is timestamp;
    }

    function validSupport(data) {
      return data.keys().hasOnly([
          'senderID',
          'recipientID',
          'targetType',
          'targetID',
          'amount',
          'amountYen',
          'transactionID',
          'productID',
          'createdAt'
        ])
        && data.senderID is string
        && data.recipientID is string
        && data.senderID != data.recipientID
        && data.targetType in ['profile', 'article', 'post']
        && (!data.keys().hasAny(['targetID']) || data.targetID is string)
        && data.amount in ['yen100', 'yen300', 'yen500', 'yen1000']
        && data.amountYen in [100, 300, 500, 1000]
        && data.transactionID is string
        && data.productID is string
        && data.createdAt is timestamp;
    }

    function validCreatorMembership(data) {
      return data.keys().hasOnly([
          'subscriberID',
          'creatorID',
          'plan',
          'monthlyYen',
          'productID',
          'latestTransactionID',
          'status',
          'updatedAt',
          'expiresAt'
        ])
        && data.subscriberID is string
        && data.creatorID is string
        && data.subscriberID != data.creatorID
        && data.plan in ['monthly300', 'monthly500', 'monthly1000']
        && data.monthlyYen in [300, 500, 1000]
        && data.productID is string
        && data.latestTransactionID is string
        && data.status == 'active'
        && data.updatedAt is timestamp
        && (!data.keys().hasAny(['expiresAt']) || data.expiresAt is timestamp);
    }

    function validFeedback(data) {
      return data.keys().hasOnly([
          'userID',
          'category',
          'message',
          'contactEmail',
          'appVersion',
          'buildNumber',
          'platform',
          'status',
          'createdAt'
        ])
        && data.userID is string
        && data.category in ['bug', 'usability', 'featureRequest', 'other']
        && data.message is string
        && data.message.size() >= 5
        && data.message.size() <= 1000
        && (!data.keys().hasAny(['contactEmail'])
          || (data.contactEmail is string && data.contactEmail.size() <= 254))
        && data.appVersion is string
        && data.appVersion.size() > 0
        && data.appVersion.size() <= 32
        && data.buildNumber is string
        && data.buildNumber.size() > 0
        && data.buildNumber.size() <= 32
        && data.platform == 'ios'
        && data.status == 'new'
        && data.createdAt is timestamp;
    }

    function validPostShare(data) {
      return data.keys().hasAll(['shareType'])
        && data.shareType in ['original', 'repost', 'quote']
        && (
          (data.shareType == 'original'
            && data.body is string
            && data.body.size() > 0)
          || (data.shareType == 'repost'
            && data.body is string
            && data.body.size() == 0
            && data.sourcePostID is string
            && data.sourcePostID.size() > 0
            && data.sourceUserID is string
            && data.sourceUserID.size() > 0)
          || (data.shareType == 'quote'
            && data.body is string
            && data.body.size() > 0
            && data.sourcePostID is string
            && data.sourcePostID.size() > 0
            && data.sourceUserID is string
            && data.sourceUserID.size() > 0)
        );
    }

    function postForComment(data) {
      return get(/databases/$(database)/documents/posts/$(data.postID));
    }

    function canCreateComment(data) {
      return exists(/databases/$(database)/documents/posts/$(data.postID))
        && postForComment(data).data.isDeleted != true
        && postForComment(data).data.moderationStatus == 'active'
        && (
          !postForComment(data).data.keys().hasAny(['commentPermission'])
          || postForComment(data).data.commentPermission == 'everyone'
          || (postForComment(data).data.commentPermission == 'following'
            && (postForComment(data).data.userID == data.userID
              || exists(/databases/$(database)/documents/follows/$(postForComment(data).data.userID + '_' + data.userID))))
        );
    }

    function ownerUserUpdateKeysAreSafe() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return changed.hasOnly([
        'displayName',
        'displayNameLowercase',
        'handle',
        'handleLowercase',
        'bio',
        'avatarUrl',
        'website',
        'location',
        'occupation',
        'email',
        'updatedAt',
        'isDeleted',
        'notificationsEnabled',
        'isAdmin',
        'isSuspended',
        'followerCount',
        'followingCount'
      ])
      && (!changed.hasAny(['isAdmin'])
        || (!resource.data.keys().hasAny(['isAdmin']) && request.resource.data.isAdmin == false))
      && (!changed.hasAny(['isSuspended'])
        || (!resource.data.keys().hasAny(['isSuspended']) && request.resource.data.isSuspended == false))
      && (!changed.hasAny(['followerCount'])
        || (!resource.data.keys().hasAny(['followerCount']) && request.resource.data.followerCount is int))
      && (!changed.hasAny(['followingCount'])
        || (!resource.data.keys().hasAny(['followingCount']) && request.resource.data.followingCount is int));
    }

    match /users/{userID} {
      allow read: if signedIn();
      allow create: if isOwner(userID)
        && request.resource.data.keys().hasOnly([
          'displayName',
          'displayNameLowercase',
          'handle',
          'handleLowercase',
          'bio',
          'avatarUrl',
          'website',
          'location',
          'occupation',
          'appleUserID',
          'email',
          'humanLevel',
          'humanVerifiedPostRate',
          'createdAt',
          'updatedAt',
          'isDeleted',
          'isAdmin',
          'isSuspended',
          'followerCount',
          'followingCount',
          'notificationsEnabled'
        ])
        && request.resource.data.isAdmin == false
        && request.resource.data.isSuspended == false
        && request.resource.data.followerCount == 0
        && request.resource.data.followingCount == 0;
      allow update: if isOwner(userID)
        && ownerUserUpdateKeysAreSafe();
      allow update: if isAdmin()
        && changedOnly([
          'isSuspended',
          'suspensionReason',
          'suspendedAt',
          'suspendedBy',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /posts/{postID} {
      allow read: if signedIn();
      allow create: if isOwner(request.resource.data.userID)
        && isActiveAccount()
        && request.resource.data.keys().hasOnly([
          'userID',
          'body',
          'mediaItems',
          'shareType',
          'sourcePostID',
          'sourceUserID',
          'commentPermission',
          'humanScore',
          'humanBadge',
          'inputDurationMs',
          'characterCount',
          'editCount',
          'deleteCount',
          'suspiciousBulkInputCount',
          'appCheckVerified',
          'aiAssisted',
          'likeCount',
          'commentCount',
          'repostCount',
          'quoteCount',
          'reactionCounts',
          'createdAt',
          'updatedAt',
          'isDeleted',
          'moderationStatus',
          'topics',
          'searchTokens'
        ])
        && validPostShare(request.resource.data)
        && validCommentPermission(request.resource.data)
        && request.resource.data.moderationStatus == 'active'
        && validPostMediaItems(request.resource.data)
        && validPostTopics(request.resource.data)
        && validPostSearchTokens(request.resource.data)
        && request.resource.data.likeCount == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.repostCount == 0
        && request.resource.data.quoteCount == 0
        && request.resource.data.reactionCounts is map
        && request.resource.data.reactionCounts.keys().size() == 0;
      allow update: if isOwner(resource.data.userID)
        && changedOnly(['body', 'topics', 'searchTokens', 'editCount', 'updatedAt', 'isDeleted', 'commentPermission'])
        && validPostTopics(request.resource.data)
        && validPostSearchTokens(request.resource.data)
        && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['commentPermission'])
          || validCommentPermission(request.resource.data));
      allow update: if isAdmin()
        && changedOnly([
          'moderationStatus',
          'hiddenReason',
          'hiddenAt',
          'hiddenBy',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /comments/{commentID} {
      allow read: if signedIn();
      allow create: if isOwner(request.resource.data.userID)
        && isActiveAccount()
        && request.resource.data.keys().hasOnly([
          'postID',
          'userID',
          'body',
          'humanScore',
          'createdAt',
          'updatedAt',
          'isDeleted',
          'moderationStatus'
        ])
        && request.resource.data.postID is string
        && request.resource.data.userID is string
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.moderationStatus == 'active'
        && canCreateComment(request.resource.data);
      allow update: if isOwner(resource.data.userID)
        && changedOnly(['updatedAt', 'isDeleted'])
        && request.resource.data.isDeleted == true;
      allow update: if signedIn()
        && exists(/databases/$(database)/documents/posts/$(resource.data.postID))
        && get(/databases/$(database)/documents/posts/$(resource.data.postID)).data.userID == request.auth.uid
        && changedOnly([
          'moderationStatus',
          'hiddenReason',
          'hiddenAt',
          'updatedAt'
        ])
        && request.resource.data.moderationStatus == 'hidden';
      allow update: if isAdmin()
        && changedOnly([
          'moderationStatus',
          'hiddenReason',
          'hiddenAt',
          'hiddenBy',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /likes/{likeID} {
      allow read: if signedIn();
      allow create: if isOwner(request.resource.data.userID)
        && isActiveAccount()
        && request.resource.data.keys().hasOnly(['postID', 'userID', 'createdAt'])
        && likeID == request.resource.data.postID + '_' + request.resource.data.userID;
      allow delete: if isOwner(resource.data.userID);
      allow update: if false;
    }

    match /reactions/{reactionID} {
      allow read: if signedIn();
      allow create: if isOwner(request.resource.data.userID)
        && isActiveAccount()
        && validReaction(request.resource.data)
        && reactionID == request.resource.data.postID + '_' + request.resource.data.userID;
      allow update: if isOwner(resource.data.userID)
        && isOwner(request.resource.data.userID)
        && isActiveAccount()
        && validReaction(request.resource.data)
        && request.resource.data.userID == resource.data.userID
        && request.resource.data.postID == resource.data.postID
        && reactionID == request.resource.data.postID + '_' + request.resource.data.userID;
      allow delete: if isOwner(resource.data.userID);
    }

    match /bookmarks/{bookmarkID} {
      allow read: if isOwner(resource.data.userID);
      allow create: if isOwner(request.resource.data.userID)
        && isActiveAccount()
        && request.resource.data.keys().hasOnly(['postID', 'userID', 'createdAt'])
        && request.resource.data.postID is string
        && bookmarkID == request.resource.data.userID + '_' + request.resource.data.postID;
      allow delete: if isOwner(resource.data.userID);
      allow update: if false;
    }

    match /follows/{followID} {
      allow read: if signedIn();
      allow create: if isOwner(request.resource.data.followerID)
        && isActiveAccount()
        && request.resource.data.keys().hasOnly(['followerID', 'followeeID', 'createdAt'])
        && request.resource.data.followerID is string
        && request.resource.data.followeeID is string
        && request.resource.data.followerID != request.resource.data.followeeID
        && followID == request.resource.data.followerID + '_' + request.resource.data.followeeID;
      allow delete: if isOwner(resource.data.followerID);
      allow update: if false;
    }

    match /blocks/{blockID} {
      allow read: if signedIn();
      allow create: if isOwner(request.resource.data.blockerID)
        && request.resource.data.keys().hasOnly(['blockerID', 'blockedUserID', 'createdAt'])
        && blockID == request.resource.data.blockerID + '_' + request.resource.data.blockedUserID;
      allow delete: if isOwner(resource.data.blockerID);
      allow update: if false;
    }

    match /mutes/{muteID} {
      allow read: if signedIn();
      allow create: if isOwner(request.resource.data.muterID)
        && request.resource.data.keys().hasOnly(['muterID', 'mutedUserID', 'createdAt'])
        && muteID == request.resource.data.muterID + '_' + request.resource.data.mutedUserID;
      allow delete: if isOwner(resource.data.muterID);
      allow update: if false;
    }

    match /mutedWords/{wordID} {
      allow read: if isOwner(resource.data.userID);
      allow create: if isOwner(request.resource.data.userID)
        && request.resource.data.keys().hasOnly(['userID', 'word', 'normalizedWord', 'createdAt'])
        && request.resource.data.word is string
        && request.resource.data.word.size() > 0
        && request.resource.data.word.size() <= 40
        && request.resource.data.normalizedWord is string
        && request.resource.data.normalizedWord.size() > 0
        && wordID.size() > request.resource.data.userID.size() + 1;
      allow delete: if isOwner(resource.data.userID);
      allow update: if false;
    }

    match /topicRooms/{topicID} {
      allow read: if signedIn();
      allow create: if isAdmin()
        && topicID == request.resource.data.topic
        && validTopicRoom(request.resource.data);
      allow update: if isAdmin()
        && topicID == resource.data.topic
        && validTopicRoom(request.resource.data);
      allow delete: if false;
    }

    match /topicFollows/{followID} {
      allow read: if isOwner(resource.data.userID);
      allow create: if isOwner(request.resource.data.userID)
        && request.resource.data.keys().hasOnly(['userID', 'topic', 'createdAt'])
        && validTopicValue(request.resource.data.topic)
        && followID == request.resource.data.userID + '_' + request.resource.data.topic;
      allow delete: if isOwner(resource.data.userID);
      allow update: if false;
    }

    match /feedControls/{controlID} {
      allow read: if isOwner(resource.data.userID);
      allow create: if isOwner(request.resource.data.userID)
        && validFeedControl(request.resource.data)
        && controlID == request.resource.data.userID + '_' + request.resource.data.targetType + '_' + request.resource.data.targetID;
      allow update: if isOwner(resource.data.userID)
        && validFeedControl(request.resource.data)
        && request.resource.data.userID == resource.data.userID
        && request.resource.data.targetType == resource.data.targetType
        && request.resource.data.targetID == resource.data.targetID
        && controlID == request.resource.data.userID + '_' + request.resource.data.targetType + '_' + request.resource.data.targetID;
      allow delete: if isOwner(resource.data.userID);
    }

    match /reports/{reportID} {
      allow read: if isOwner(resource.data.reporterID) || isAdmin();
      allow create: if isOwner(request.resource.data.reporterID)
        && request.resource.data.keys().hasOnly([
          'reporterID',
          'targetType',
          'targetID',
          'targetOwnerID',
          'targetDescription',
          'reason',
          'status',
          'createdAt'
        ])
        && request.resource.data.status == '確認待ち';
      allow update: if isAdmin()
        && changedOnly(['status', 'adminNote', 'resolvedAt', 'resolvedBy']);
      allow delete: if false;
    }

    match /feedback/{feedbackID} {
      allow read: if isOwner(resource.data.userID) || isAdmin();
      allow create: if isOwner(request.resource.data.userID)
        && validFeedback(request.resource.data);
      allow update: if isAdmin()
        && changedOnly(['status', 'adminNote', 'resolvedAt', 'resolvedBy']);
      allow delete: if false;
    }

    match /notifications/{notificationID} {
      allow read: if isOwner(resource.data.recipientID);
      allow update: if isOwner(resource.data.recipientID)
        && changedOnly(['isRead', 'readAt']);
      allow create, delete: if false;
    }

    match /inviteCodes/{code} {
      allow read: if signedIn()
        && (resource.data.inviterID == request.auth.uid || isAdmin());
      allow create: if isOwner(request.resource.data.inviterID)
        && isActiveAccount()
        && request.resource.data.keys().hasOnly([
          'code',
          'inviterID',
          'maxUses',
          'useCount',
          'isActive',
          'createdAt',
          'updatedAt',
          'expiresAt'
        ])
        && code == request.resource.data.code
        && request.resource.data.code is string
        && request.resource.data.code.size() >= 6
        && request.resource.data.code.size() <= 24
        && request.resource.data.maxUses is int
        && request.resource.data.maxUses > 0
        && request.resource.data.maxUses <= 20
        && request.resource.data.useCount == 0
        && request.resource.data.isActive == true
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (!request.resource.data.keys().hasAny(['expiresAt'])
          || request.resource.data.expiresAt is timestamp);
      allow update, delete: if false;
    }

    match /inviteRedemptions/{redemptionID} {
      allow read: if signedIn()
        && (resource.data.inviteeID == request.auth.uid
          || resource.data.inviterID == request.auth.uid
          || isAdmin());
      allow create: if isOwner(request.resource.data.inviteeID)
        && isActiveAccount()
        && request.resource.data.keys().hasOnly(['code', 'inviteeID', 'createdAt'])
        && request.resource.data.code is string
        && request.resource.data.code.size() >= 6
        && request.resource.data.code.size() <= 24
        && redemptionID == request.resource.data.code + '_' + request.resource.data.inviteeID
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    match /creatorMemberships/{membershipID} {
      allow read: if signedIn()
        && (resource.data.subscriberID == request.auth.uid
          || resource.data.creatorID == request.auth.uid
          || isAdmin());
      allow create, update: if false;
      allow delete: if false;
    }

    match /supports/{supportID} {
      allow read: if signedIn()
        && (resource.data.senderID == request.auth.uid
          || resource.data.recipientID == request.auth.uid
          || isAdmin());
      allow create: if false;
      allow update, delete: if false;
    }

    match /fcmTokens/{userID}/tokens/{tokenID} {
      allow read, write: if isOwner(userID);
    }

    match /articles/{articleID} {
      allow read: if signedIn();
      allow create: if isOwner(request.resource.data.userID)
        && isActiveAccount()
        && request.resource.data.keys().hasOnly([
          'userID', 'title', 'freePreviewBody', 'status', 'price',
          'topics', 'searchTokens', 'commentPermission',
          'humanBadge', 'humanScore', 'inputDurationMs', 'editCount', 'deleteCount',
          'commentCount', 'purchaseCount', 'bookmarkCount',
          'createdAt', 'updatedAt', 'isDeleted', 'moderationStatus'
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 100
        && request.resource.data.freePreviewBody is string
        && request.resource.data.freePreviewBody.size() > 0
        && request.resource.data.commentCount == 0
        && request.resource.data.purchaseCount == 0
        && request.resource.data.bookmarkCount == 0
        && request.resource.data.isDeleted == false
        && request.resource.data.moderationStatus == 'active'
        && request.resource.data.status in ['draft', 'published', 'unpublished']
        && request.resource.data.price in ['free', 'yen100', 'yen300', 'yen500', 'yen800', 'yen1000'];
      allow update: if isOwner(resource.data.userID)
        && changedOnly(['title', 'freePreviewBody', 'status', 'topics', 'searchTokens', 'updatedAt', 'isDeleted', 'commentPermission'])
        && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['isDeleted'])
          || request.resource.data.isDeleted == true);
      allow update: if isAdmin()
        && changedOnly(['moderationStatus', 'hiddenReason', 'hiddenAt', 'hiddenBy', 'updatedAt']);
      allow delete: if false;
    }

    match /articleBodies/{articleID} {
      allow read: if signedIn()
        && (
          !exists(/databases/$(database)/documents/articles/$(articleID))
          || get(/databases/$(database)/documents/articles/$(articleID)).data.price == 'free'
          || exists(/databases/$(database)/documents/articleUnlocks/$(request.auth.uid + '_' + articleID))
          || get(/databases/$(database)/documents/articles/$(articleID)).data.userID == request.auth.uid
        );
      allow write: if false;
    }

    match /articleUnlocks/{unlockID} {
      allow read: if signedIn() && unlockID.matches(request.auth.uid + '_.*');
      allow create: if false;
      allow update, delete: if false;
    }

	    match /creatorRevenueEvents/{eventID} {
	      allow read: if signedIn()
	        && (resource.data.creatorID == request.auth.uid
	          || resource.data.payerID == request.auth.uid
	          || isAdmin());
	      allow write: if false;
	    }

    match /articleBookmarks/{bookmarkID} {
      allow read: if isOwner(resource.data.userID);
      allow create: if isOwner(request.resource.data.userID)
        && isActiveAccount()
        && request.resource.data.keys().hasOnly(['userID', 'articleID', 'createdAt'])
        && bookmarkID == request.resource.data.userID + '_' + request.resource.data.articleID;
      allow delete: if isOwner(resource.data.userID);
      allow update: if false;
    }
  }
}
